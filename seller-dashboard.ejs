<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Seller Dashboard - LuxeStore Ultra</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<header class="navbar">
  <div class="logo">Seller <span>Dashboard</span></div>
  <nav>
    <a href="/">Home</a>
    <a href="/add-product">Add Product</a>
    <a href="/orders">Orders</a>
    <a href="/logout">Logout</a>
  </nav>
</header>

<section class="section">
  <h2>Your Products</h2>
  <div class="product-grid">
    <% products.forEach(product => { %>
      <div class="product-card">
        <img src="<%= product.image %>" alt="<%= product.name %>">
        <h3><%= product.name %></h3>
        <p><%= product.description %></p>
        <div class="price">₹<%= product.price %></div>
        <a href="/delete-product/<%= product._id %>" class="btn">Delete</a>
      </div>
    <% }) %>
  </div>
</section>
</body>
</html>