<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>LuxeStore Ultra</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<header class="navbar">
  <div class="logo">LuxeStore <span>Ultra</span></div>
  <nav>
    <a href="/">Home</a>
    <a href="/products">Shop</a>
    <a href="/cart">Cart</a>
    <a href="/wishlist">Wishlist</a>
    <a href="/orders">Orders</a>
    <% if(user) { %>
      <a href="/logout">Logout</a>
    <% } else { %>
      <a href="/login">User Login</a>
    <% } %>
    <a href="/seller-login">Seller Login</a>
  </nav>
</header>

<section class="hero">
  <div class="hero-content">
    <h1>Luxury Shopping. Reinvented.</h1>
    <p>Discover premium products with an elite shopping experience.</p>
    <a href="/products" class="btn">Explore Collection</a>
    <button class="btn secondary" onclick="openSpin()">🎡 Spin & Win</button>
  </div>
</section>

<section class="section">
  <h2>Trending Products</h2>
  <div class="product-grid">
    <% products.forEach(product => { %>
      <div class="product-card">
        <img src="<%= product.image %>" alt="<%= product.name %>">
        <h3><%= product.name %></h3>
        <p><%= product.description %></p>
        <div class="price">₹<%= product.price %></div>
        <a href="/product/<%= product._id %>" class="btn">View</a>
      </div>
    <% }) %>
  </div>
</section>

<div class="spin-modal" id="spinModal">
  <div class="spin-box">
    <span class="close" onclick="closeSpin()">&times;</span>
    <h2>🎡 Spin & Win</h2>
    <div class="wheel" id="wheel">SPIN</div>
    <button class="btn" onclick="spinWheel()">Spin Now</button>
    <p id="spin-result"></p>
  </div>
</div>

<footer>© 2026 LuxeStore Ultra</footer>
<script src="/script.js"></script>
</body>
</html>